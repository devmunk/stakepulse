  "outputDirectory": "frontend/.next",
  "installCommand": "cd frontend && npm install",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_CONTRACT_ID": "@stakepulse_contract_id",
    "NEXT_PUBLIC_NETWORK": "@stakepulse_network",
    "NEXT_PUBLIC_TOKEN_ADDRESS": "@stakepulse_token_address"
  }
}
